# ── Backend ───────────────────────────────────────────────────────────────────

# Port the Express server will listen on
PORT=5000

# Full MongoDB connection string (local dev default)
# Docker Compose overrides this to mongodb://mongodb:27017/smart-leads-dashboard
MONGO_URI=mongodb://localhost:27017/smart-leads-dashboard

# Database name (used by Docker Compose for MONGO_INITDB_DATABASE)
MONGO_DB_NAME=smart-leads-dashboard

# Secret used to sign JWT tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret

# Token expiry: 7d | 24h | 3600 (seconds)
JWT_EXPIRES_IN=7d

# Environment: development | production
NODE_ENV=development

# URL of the deployed frontend (used to whitelist CORS in production)
# Set this on Render to your Vercel URL, e.g. https://smart-leads.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# Comma-separated list of additional allowed CORS origins (optional)
# CORS_ORIGIN=http://localhost:5173,https://your-app.vercel.app
