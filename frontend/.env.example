# ── Frontend ──────────────────────────────────────────────────────────────────

# Base URL for API calls. Leave as /api in development — Vite proxy handles it.
# In production, set to the full backend URL (e.g. https://api.yourapp.com/api)
VITE_API_URL=/api

# Backend URL for Vite's dev proxy target (dev only — not used in production builds)
# Defaults to http://localhost:5000 if not set
VITE_API_TARGET=http://localhost:5000
