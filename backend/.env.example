# ── Server ────────────────────────────────────────────────────────────────────

PORT=8000

# ── MongoDB ───────────────────────────────────────────────────────────────────

# Local development default
# Docker Compose overrides this automatically to mongodb://mongodb:27017/smart-leads-dashboard
MONGO_URI=mongodb://localhost:27017/smart-leads-dashboard

# Database name (used by Docker Compose for MONGO_INITDB_DATABASE)
MONGO_DB_NAME=smart-leads-dashboard

# ── JWT ───────────────────────────────────────────────────────────────────────

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret_at_least_32_chars

# Token expiry: 7d | 24h | 3600 (seconds)
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173

# ── Environment ───────────────────────────────────────────────────────────────

# development | production
NODE_ENV=development
